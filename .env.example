# =========================
# Application
# =========================

APP_NAME=Smart Telemetry Governance
APP_ENV=development
APP_HOST=127.0.0.1
APP_PORT=8000
DEBUG=true
LOG_LEVEL=INFO
CORS_ORIGINS=["http://localhost:5173","http://127.0.0.1:5173"]

# =========================
# PostgreSQL
# =========================

POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=smartmqtt
POSTGRES_USER=smartmqtt
POSTGRES_PASSWORD=replace_with_local_dev_password
DATABASE_URL=postgresql+psycopg://smartmqtt:replace_with_local_dev_password@localhost:5432/smartmqtt
DATABASE_REQUIRED=false

# =========================
# InfluxDB
# =========================

INFLUXDB_URL=http://localhost:8086
INFLUXDB_ORG=smarttelemetry
INFLUXDB_BUCKET=telemetry
INFLUXDB_TOKEN=replace_me

# =========================
# MQTT
# =========================

MQTT_HOST=localhost
MQTT_PORT=1883
MQTT_CLIENT_ID=smarttelemetry
MQTT_ENABLED=false
MQTT_SOURCE_ID=local-development-broker
MQTT_USERNAME=replace_with_local_dev_username
MQTT_PASSWORD=replace_with_local_dev_password
MQTT_TLS_ENABLED=false
MQTT_TLS_VERIFY=true
MQTT_TOPIC_ALLOWLIST=["site/+/telemetry/#"]
MQTT_MAX_PAYLOAD_BYTES=65536
EVIDENCE_PREVIEW_BYTES=512
# Development defaults only; production values require policy validation.
OBSERVATION_FUTURE_SKEW_SECONDS=300
OBSERVATION_FALLBACK_WINDOW_SECONDS=60

# =========================
# ChromaDB
# =========================

CHROMA_HOST=localhost
CHROMA_PORT=8000
