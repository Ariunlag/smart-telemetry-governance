# =========================
# Application
# =========================

APP_NAME=Smart Telemetry Governance
APP_ENV=development
DEBUG=true

# =========================
# PostgreSQL
# =========================

POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=smarttelemetry
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# =========================
# InfluxDB
# =========================

INFLUXDB_URL=http://localhost:8086
INFLUXDB_ORG=smarttelemetry
INFLUXDB_BUCKET=telemetry
INFLUXDB_TOKEN=replace_me

# =========================
# MQTT
# =========================

MQTT_HOST=localhost
MQTT_PORT=1883
MQTT_CLIENT_ID=smarttelemetry

# =========================
# ChromaDB
# =========================

CHROMA_HOST=localhost
CHROMA_PORT=8000

# =========================
# Logging
# =========================

LOG_LEVEL=INFO