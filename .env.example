# =========================
# Application
# =========================

APP_NAME=Smart Telemetry Governance
APP_ENV=development
APP_HOST=127.0.0.1
APP_PORT=8000
DEBUG=true
LOG_LEVEL=INFO
CORS_ORIGINS=["http://localhost:5173","http://127.0.0.1:5173"]

# =========================
# PostgreSQL
# =========================

POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=smartmqtt
POSTGRES_USER=smartmqtt
POSTGRES_PASSWORD=replace_with_local_dev_password
DATABASE_URL=postgresql+psycopg://smartmqtt:replace_with_local_dev_password@localhost:5432/smartmqtt
DATABASE_REQUIRED=false

# =========================
# InfluxDB
# =========================

INFLUXDB_URL=http://localhost:8086
INFLUXDB_ORG=smarttelemetry
INFLUXDB_BUCKET=telemetry
INFLUXDB_TOKEN=replace_with_local_dev_token
# Development-only setup values. Production credentials must come from secret management.
DOCKER_INFLUXDB_INIT_MODE=setup
DOCKER_INFLUXDB_INIT_USERNAME=smarttelemetry
DOCKER_INFLUXDB_INIT_PASSWORD=replace_with_local_dev_password
DOCKER_INFLUXDB_INIT_ADMIN_TOKEN=replace_with_local_dev_token
DOCKER_INFLUXDB_INIT_ORG=smarttelemetry
DOCKER_INFLUXDB_INIT_BUCKET=telemetry
INFLUXDB_ENABLED=false
INFLUXDB_VERIFY_SSL=true
INFLUXDB_TIMEOUT_MS=10000
# Development placeholders only. Production secrets must come from secret management.
OUTBOX_WORKER_POLL_INTERVAL_MS=1000
OUTBOX_WORKER_BATCH_SIZE=25
OUTBOX_PROCESSING_LEASE_SECONDS=60
OUTBOX_MAX_ATTEMPTS=5
OUTBOX_BACKOFF_BASE_SECONDS=5
OUTBOX_BACKOFF_MAX_SECONDS=300

# Deterministic schema-observation worker. Disabled by default; production values require policy validation.
SCHEMA_OBSERVATION_WORKER_ENABLED=false
SCHEMA_OBSERVATION_WORKER_POLL_INTERVAL_MS=1000
SCHEMA_OBSERVATION_WORKER_BATCH_SIZE=10
SCHEMA_OBSERVATION_WORKER_LEASE_SECONDS=30
SCHEMA_OBSERVATION_WORKER_MAX_ATTEMPTS=5
SCHEMA_OBSERVATION_WORKER_BACKOFF_BASE_SECONDS=2
SCHEMA_OBSERVATION_WORKER_BACKOFF_MAX_SECONDS=300

# =========================
# MQTT
# =========================

MQTT_HOST=localhost
MQTT_PORT=1883
MQTT_CLIENT_ID=smarttelemetry
MQTT_ENABLED=false
MQTT_SOURCE_ID=local-development-broker
MQTT_USERNAME=replace_with_local_dev_username
MQTT_PASSWORD=replace_with_local_dev_password
MQTT_TLS_ENABLED=false
MQTT_TLS_VERIFY=true
MQTT_TOPIC_ALLOWLIST=["site/+/telemetry/#"]
MQTT_MAX_PAYLOAD_BYTES=65536
EVIDENCE_PREVIEW_BYTES=512
# Development default only. Physical raw-payload cleanup is not implemented yet.
RAW_OBSERVATION_RETENTION_DAYS=30
# Development defaults only; production values require policy validation.
OBSERVATION_FUTURE_SKEW_SECONDS=300
OBSERVATION_FALLBACK_WINDOW_SECONDS=60

# =========================
# ChromaDB
# =========================

CHROMA_HOST=localhost
CHROMA_PORT=8000
