classDiagram
    class NormalizedMessage {
        +str source_id
        +str source_type
        +str topic
        +datetime timestamp
        +Any value
        +str unit
        +float quality
        +dict metadata
    }

    class Event {
        +str type
        +dict data
        +datetime timestamp
        +str source
    }

    class BaseSourceAdapter {
        <<interface>>
        +str source_id
        +SourceConfig config
        +Callable on_message
        +connect() bool
        +disconnect() None
        +subscribe(topics) None
        +unsubscribe(topics) None
        +get_status() str
        +get_message_count() int
        +get_error_count() int
        +_normalize(raw) NormalizedMessage
    }

    class MQTTAdapter {
        +connect() bool
        +subscribe(topics) None
        +unsubscribe(topics) None
        +_normalize(raw) NormalizedMessage
        +_on_mqtt_message(client, userdata, msg) None
    }

    class RESTAdapter {
        +int poll_interval
        +connect() bool
        +disconnect() None
        +_poll() None
        +_normalize(raw) NormalizedMessage
    }

    class FileAdapter {
        +connect() bool
        +ingest() int
        +_parse_csv(path) list
        +_parse_json(path) list
        +_normalize(raw) NormalizedMessage
    }

    class EventBus {
        +publish(event) None
        +subscribe(event_type, handler) None
        +unsubscribe(event_type, handler) None
        +publish_and_wait(event, timeout) list
    }

    class BaseModule {
        <<interface>>
        +str module_id
        +str version
        +start() None
        +stop() None
        +health_check() bool
    }

    class ModuleRegistry {
        +register(module) None
        +unregister(module_id) None
        +get(module_id) BaseModule
        +list_all() list
        +list_healthy() list
        +start_all() None
        +stop_all() None
    }

    class BaseTool {
        <<interface>>
        +str tool_id
        +str description
        +list capabilities
        +dict input_schema
        +dict output_schema
        +execute(params) dict
    }

    class ToolRegistry {
        +register(tool) None
        +get(tool_id) BaseTool
        +list_all() list
        +list_by_capability(capability) list
        +execute(tool_id, params) dict
    }

    class SourceManager {
        +add_source(config) str
        +remove_source(source_id) None
        +get_source(source_id) SourceConfig
        +list_sources() list
        +get_source_status(source_id) SourceStatus
        +add_topic_subscription(source_id, topic) None
        +remove_topic_subscription(source_id, topic) None
    }

    BaseSourceAdapter <|.. MQTTAdapter
    BaseSourceAdapter <|.. RESTAdapter
    BaseSourceAdapter <|.. FileAdapter

    SourceManager --> BaseSourceAdapter
    SourceManager --> EventBus
    EventBus --> Event
    EventBus --> ModuleRegistry
    ModuleRegistry --> BaseModule
    ToolRegistry --> BaseTool
    BaseSourceAdapter --> NormalizedMessage