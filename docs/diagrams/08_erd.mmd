erDiagram
    SOURCES {
        uuid id PK
        string name
        string source_type
        json config_json
        string status
        datetime created_at
        datetime updated_at
    }

    SUBSCRIPTIONS {
        uuid id PK
        uuid source_id FK
        string topic_pattern
        bool is_active
        datetime created_at
        datetime updated_at
    }

    TOPICS {
        uuid id PK
        uuid source_id FK
        string external_topic
        string normalized_topic
        string unit
        json metadata_json
        datetime first_seen_at
        datetime last_seen_at
    }

    CLASSES {
        uuid id PK
        string name
        string description
        json metadata_json
        datetime created_at
    }

    TOPIC_CLASSES {
        uuid id PK
        uuid topic_id FK
        uuid class_id FK
        float confidence
        string assigned_by
        datetime created_at
    }

    MODULES {
        uuid id PK
        string name
        string version
        bool enabled
        json config_json
        datetime created_at
    }

    MODULE_RUNS {
        uuid id PK
        uuid module_id FK
        string status
        datetime started_at
        datetime ended_at
        json metrics_json
    }

    MODULE_OUTPUTS {
        uuid id PK
        uuid module_id FK
        uuid module_run_id FK
        string target_type
        uuid target_id
        string output_type
        json output_json
        datetime created_at
    }

    DECISIONS {
        uuid id PK
        string decision_type
        string status
        uuid target_id
        json decision_json
        string decided_by
        datetime created_at
    }

    QUALITY_SCORES {
        uuid id PK
        uuid topic_id FK
        float completeness
        float consistency
        float timeliness
        float accuracy
        float overall
        datetime scored_at
    }

    ALERTS {
        uuid id PK
        uuid topic_id FK
        string alert_type
        string severity
        float score
        string status
        json evidence_json
        string acknowledged_by
        datetime created_at
        datetime acknowledged_at
    }

    CLUSTERS {
        uuid id PK
        string algorithm
        float silhouette_score
        json topic_ids
        json metadata_json
        datetime computed_at
    }

    PROVENANCE_EVENTS {
        uuid id PK
        uuid source_id FK
        uuid topic_id FK
        string event_type
        string actor
        json details_json
        datetime created_at
    }

    SOURCES ||--o{ SUBSCRIPTIONS : has
    SOURCES ||--o{ TOPICS : contains
    SOURCES ||--o{ PROVENANCE_EVENTS : emits

    TOPICS ||--o{ TOPIC_CLASSES : assigned_to
    CLASSES ||--o{ TOPIC_CLASSES : includes

    TOPICS ||--o{ QUALITY_SCORES : scored_by
    TOPICS ||--o{ ALERTS : generates
    TOPICS ||--o{ PROVENANCE_EVENTS : has

    MODULES ||--o{ MODULE_RUNS : executes
    MODULES ||--o{ MODULE_OUTPUTS : produces
    MODULE_RUNS ||--o{ MODULE_OUTPUTS : contains